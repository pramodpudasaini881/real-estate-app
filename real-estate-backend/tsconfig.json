{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "es2022",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "types": ["node", "jest"],
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist"
  },
  "ts-node": {
    "compilerOptions": {
      "module": "CommonJS"
    }
  }
}
